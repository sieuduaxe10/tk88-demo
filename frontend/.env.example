# Frontend Environment Variables
# Copy to .env.local and fill in actual values

# tk88-lite backend (Railway URL after deploy, e.g. https://tk88-backend-production.up.railway.app)
VITE_API_BASE_URL=http://localhost:3002

# Legacy API & WebSocket (not used by tk88-lite)
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000

# App Config
VITE_APP_NAME=TK88 Gaming
VITE_APP_VERSION=1.0.0

# Features
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SENTRY=false

# Third-party services
VITE_SENTRY_DSN=
VITE_STRIPE_PUBLIC_KEY=pk_test_your_key
